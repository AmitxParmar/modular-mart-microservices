_format_version: "3.0"

# ─────────────────────────────────────
# UPSTREAMS: Health-based Load Balancing
#
# TARGET format: host:port
# - Docker/local: e.g. catalog-service:3005  (HTTP, internal Docker network)
# - Render:       e.g. catalog-service-xxxx.onrender.com:443  (HTTPS, public)
#
# Env vars injected by entrypoint.sh envsubst:
#   *_SERVICE_HOST  — hostname only  (set via docker-compose env / render.yaml fromService.host)
#   *_SERVICE_PORT  — port number    (3005 locally, 443 on Render)
#   UPSTREAM_PROTOCOL — http locally, https on Render
# ─────────────────────────────────────
upstreams:
- name: user-service-upstream
  algorithm: round-robin
  targets:
  - target: ${USER_SERVICE_HOST}:${USER_SERVICE_PORT}
  healthchecks:
    active:
      http_path: /health/live
      https_verify_certificate: false
      healthy:
        interval: 10
        successes: 2
      unhealthy:
        interval: 5
        http_failures: 3

- name: catalog-service-upstream
  algorithm: round-robin
  targets:
  - target: ${CATALOG_SERVICE_HOST}:${CATALOG_SERVICE_PORT}
  healthchecks:
    active:
      http_path: /health/live
      https_verify_certificate: false
      healthy:
        interval: 10
        successes: 2
      unhealthy:
        interval: 5
        http_failures: 3

- name: order-service-upstream
  algorithm: round-robin
  targets:
  - target: ${ORDER_SERVICE_HOST}:${ORDER_SERVICE_PORT}
  healthchecks:
    active:
      http_path: /health/live
      https_verify_certificate: false
      healthy:
        interval: 10
        successes: 2
      unhealthy:
        interval: 5
        http_failures: 3

- name: payment-service-upstream
  algorithm: round-robin
  targets:
  - target: ${PAYMENT_SERVICE_HOST}:${PAYMENT_SERVICE_PORT}
  healthchecks:
    active:
      http_path: /health/live
      https_verify_certificate: false
      healthy:
        interval: 10
        successes: 2
      unhealthy:
        interval: 5
        http_failures: 3

- name: notification-service-upstream
  algorithm: round-robin
  targets:
  - target: ${NOTIFICATION_SERVICE_HOST}:${NOTIFICATION_SERVICE_PORT}
  healthchecks:
    active:
      http_path: /health/live
      https_verify_certificate: false
      healthy:
        interval: 10
        successes: 2
      unhealthy:
        interval: 5
        http_failures: 3

# ─────────────────────────────────────
# SERVICES & ROUTES: API Definition
# ─────────────────────────────────────
services:
# Health check shortcut — intercepted by request-termination before upstream is hit
- name: gateway-health
  url: http://localhost:8001
  routes:
  - name: gateway-health-route
    paths:
    - /healthz
  plugins:
  - name: request-termination
    config:
      status_code: 200
      message: "Kong Gateway is healthy"

- name: user-service
  host: user-service-upstream
  protocol: ${UPSTREAM_PROTOCOL}
  connect_timeout: 10000
  read_timeout: 30000
  write_timeout: 30000
  routes:
  - name: user-routes
    paths:
    - /api/users
    strip_path: false
  plugins:
  - name: rate-limiting
    config:
      policy: local
      minute: 100
  - name: request-transformer
    config:
      add:
        headers:
        - "X-Gateway-Secret:${GATEWAY_INTERNAL_SECRET}"

- name: catalog-service
  host: catalog-service-upstream
  protocol: ${UPSTREAM_PROTOCOL}
  connect_timeout: 10000
  read_timeout: 30000
  write_timeout: 30000
  routes:
  - name: catalog-routes
    paths:
    - /api/catalog
    strip_path: false
  plugins:
  - name: rate-limiting
    config:
      policy: local
      minute: 200
  - name: request-transformer
    config:
      add:
        headers:
        - "X-Gateway-Secret:${GATEWAY_INTERNAL_SECRET}"

- name: order-service
  host: order-service-upstream
  protocol: ${UPSTREAM_PROTOCOL}
  connect_timeout: 10000
  read_timeout: 30000
  write_timeout: 30000
  routes:
