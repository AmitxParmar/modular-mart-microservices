    config:
      policy: local
      minute: 50
  - name: request-transformer
    config:
      add:
        headers:
        - "X-Gateway-Secret:${GATEWAY_INTERNAL_SECRET}"

- name: payment-service
  host: payment-service-upstream
  protocol: ${UPSTREAM_PROTOCOL}
  connect_timeout: 10000
  read_timeout: 30000
  write_timeout: 30000
  routes:
  - name: payment-routes
    paths:
    - /api/payments
    strip_path: false
  plugins:
  - name: rate-limiting
    config:
      policy: local
      minute: 30
  - name: request-transformer
    config:
      add:
        headers:
        - "X-Gateway-Secret:${GATEWAY_INTERNAL_SECRET}"

- name: notification-service
  host: notification-service-upstream
  protocol: ${UPSTREAM_PROTOCOL}
  connect_timeout: 10000
  read_timeout: 30000
  write_timeout: 30000
  routes:
  - name: notification-routes
    paths:
    - /api/notifications
    strip_path: false
  plugins:
  - name: rate-limiting
