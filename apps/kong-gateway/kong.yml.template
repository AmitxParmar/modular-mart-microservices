        - "X-Gateway-Secret:${GATEWAY_INTERNAL_SECRET}"

# ─────────────────────────────────────
# GLOBAL PLUGINS
#
# NOT included:
#   prometheus — stores a full in-memory histogram of every route × status code
#                × latency bucket since container start. Nothing scrapes it on
#                Render free-tier, so it's pure memory waste (~50-100MB over time).
#                Re-enable if you add a Prometheus scraper to your stack.
# ─────────────────────────────────────
plugins:
- name: correlation-id
  config:
    header_name: x-request-id
    generator: uuid
    echo_downstream: true

- name: response-transformer
  config:
    add:
      headers:
      - "X-Frame-Options:DENY"
      - "X-Content-Type-Options:nosniff"
      - "Strict-Transport-Security:max-age=31536000"

- name: cors
  config:
    origins:
    - http://localhost:3000
    - http://localhost:4000
    - https://modular-mart-microservices-web.vercel.app
    - /^https:\/\/modular-mart-microservices.*\.vercel\.app$/
    - ${FRONTEND_URL}
    credentials: true
    exposed_headers:
    - x-request-id

- name: request-size-limiting
  config:
    allowed_payload_size: 10
    size_unit: megabytes
