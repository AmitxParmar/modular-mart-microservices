GATEWAY_INTERNAL_SECRET=ecommerce-internal-trust-2026-xyz

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
# Required for Kong's jwt plugin to verify Clerk-issued RS256 tokens.
#
# CLERK_ISSUER_URL: Your Clerk Frontend API URL (found in Clerk Dashboard → API Keys).
#   Must match the `iss` claim in the Clerk JWT exactly.
#   Example: https://your-app.clerk.accounts.dev
#
# CLERK_JWT_PUBLIC_KEY: The RS256 public key from Clerk Dashboard → API Keys →
#   "Show JWT Public Key". Copy the full PEM including header/footer.
#   Newlines must be literal \n when set in Render dashboard.
CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev
CLERK_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----"

# Optional while rate limiting uses the local development policy.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
