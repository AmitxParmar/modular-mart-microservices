{
  "name": "@repo/common",
  "version": "0.0.1",
  "private": true,
  "description": "Shared NestJS runtime utilities: exception filter, logger config, health controller",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "messaging": [
        "dist/messaging/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./messaging": {
      "types": "./dist/messaging/index.d.ts",
      "default": "./dist/messaging/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/microservices": "^11.0.0",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.4",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/nestjs": "^10.53.1",
    "@sentry/profiling-node": "^10.53.1",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "pino-std-serializers": "^7.0.0"
  }
}
